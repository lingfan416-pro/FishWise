// Universal fallback
const defaultRecommendation = {
  fish: 'Bluegill (Panfish)',
  bait: 'Small worm or cricket',
  lineDepth: 'shallow',
  sinkerWeight: 'light',
  floatType: 'standard bobber',
  reason: 'Bluegill are beginner-friendly and respond well to simple bobber rigs in almost all conditions.'
};

// ============================================================================
// ROUTES
// ============================================================================

// GET /api/spots - Return all available fishing spots
app.get('/api/spots', (req, res) => {
  res.json({ spots: fishingSpots });
});

// POST /api/recommendation - Get a fishing recommendation
app.post('/api/recommendation', (req, res) => {
  const { location, timeOfDay, weather, windLevel, targetFish } = req.body;

  // Validate required fields
  if (!location || !timeOfDay || !weather || !windLevel) {
    return res.status(400).json({
      error: 'Missing required fields: location, timeOfDay, weather, windLevel'
    });
  }

  // Find the location and get water type
  const spot = fishingSpots.find((s) => s.id === location);
  if (!spot) {
    return res.status(400).json({ error: 'Invalid location' });
  }

  const waterType = spot.waterType;

  // Find matching recommendation rule (best match first, then fallback)
  let recommendation = findRecommendation(
    waterType,
    targetFish,
    timeOfDay,
    weather,
    windLevel
  );

  res.json({
    location: spot.name,
    waterType,
    timeOfDay,
    weather,
    windLevel,
    targetFish: targetFish || 'Not specified',
    recommendation
  });
});

// Health check endpoint
app.get('/api/health', (req, res) => {
  res.json({ status: 'ok' });
});

// ============================================================================
// RECOMMENDATION ENGINE
// ============================================================================

function findRecommendation(waterType, targetFish, timeOfDay, weather, windLevel) {
  // Try exact match (all conditions match)
  let rule = recommendationRules.find(
    (r) =>
      r.waterType === waterType &&
      r.targetFish === targetFish &&
      r.timeOfDay === timeOfDay &&
      r.weather === weather &&
      r.windLevel === windLevel
  );
  if (rule) return rule.recommendation;

  // Try with target fish and water type (more permissive)
  rule = recommendationRules.find(
    (r) =>
      r.waterType === waterType &&
      r.targetFish === targetFish &&
      r.timeOfDay === timeOfDay &&
      r.weather === weather
  );
  if (rule) return rule.recommendation;

  // Try with water type, time of day, and weather
  rule = recommendationRules.find(
    (r) =>
      r.waterType === waterType &&
      r.timeOfDay === timeOfDay &&
      r.weather === weather
  );
  if (rule) return rule.recommendation;

  // Try with just water type and time of day
  rule = recommendationRules.find(
    (r) => r.waterType === waterType && r.timeOfDay === timeOfDay
  );
  if (rule) return rule.recommendation;

  // Return universal default if nothing matches
  return defaultRecommendation;
}

// ============================================================================
// ERROR HANDLING & SERVER START
// ============================================================================

app.use((req, res) => {
  res.status(404).json({ error: 'Route not found' });
});

app.use((err, req, res, next) => {
  console.error(err.stack);
  res.status(500).json({ error: 'Internal server error' });
});

const PORT = process.env.PORT || 5000;
app.listen(PORT, () => {
  console.log(`FishWise backend running on http://localhost:${PORT}`);
});

module.exports = app;